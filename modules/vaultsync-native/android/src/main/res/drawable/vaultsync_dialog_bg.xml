<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded surface background for the autofill save dialog. Inset keeps the
     default dialog margins so the rounded card floats above the scrim. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="16dp"
    android:insetRight="16dp"
    android:insetTop="24dp"
    android:insetBottom="24dp">
  <shape android:shape="rectangle">
    <solid android:color="@color/vaultsync_dialog_bg" />
    <corners android:radius="20dp" />
  </shape>
</inset>
